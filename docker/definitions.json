{
  "vhosts": [
    { "name": "/" }
  ],
  "users": [
    {
      "name": "book_user",
      "password": "book_password",
      "tags": "administrator"
    }
  ],
  "permissions": [
    {
      "user": "book_user",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "book.events",
      "vhost": "/",
      "type": "topic",
      "durable": true
    },
    {
      "name": "book.events.dlx",
      "vhost": "/",
      "type": "topic",
      "durable": true
    }
  ],
  "queues": [
    {
      "name": "client.book.queue",
      "vhost": "/",
      "durable": true,
      "arguments": {
        "x-dead-letter-exchange": "book.events.dlx",
        "x-dead-letter-routing-key": "client.created.dlq"
      }
    },
    {
      "name": "client.book.queue.retry",
      "vhost": "/",
      "durable": true,
      "arguments": {
        "x-dead-letter-exchange": "book.events",
        "x-dead-letter-routing-key": "client.created"
      }
    },
    {
      "name": "client.book.queue.dlq",
      "vhost": "/",
      "durable": true
    },

    {
      "name": "notification.client.created.queue",
      "vhost": "/",
      "durable": true
    }
  ],
  "bindings": [
    {
      "source": "book.events",
      "vhost": "/",
      "destination": "client.book.queue",
      "destination_type": "queue",
      "routing_key": "client.created"
    },
    {
      "source": "book.events",
      "vhost": "/",
      "destination": "client.book.queue.retry",
      "destination_type": "queue",
      "routing_key": "client.retry"
    },
    {
      "source": "book.events.dlx",
      "vhost": "/",
      "destination": "client.book.queue.dlq",
      "destination_type": "queue",
      "routing_key": "client.created.dlq"
    },

    {
      "source": "book.events",
      "vhost": "/",
      "destination": "notification.client.created.queue",
      "destination_type": "queue",
      "routing_key": "client.created"
    }
  ]
}
